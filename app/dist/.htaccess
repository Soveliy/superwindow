<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /calc/

  # Let the server handle existing files and directories normally.
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # For SPA routes like /calc/orders or /calc/settings, always serve the app shell.
  RewriteRule ^ index.html [L]
</IfModule>
